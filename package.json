{
  "name": "medical-supplier-erp-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c red,blue \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:server": "npm run dev:api",
    "server": "tsx server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -b && npm run typecheck:api && vite build",
    "typecheck:api": "tsc --noEmit --ignoreConfig --module NodeNext --moduleResolution NodeNext --target ES2022 --esModuleInterop --allowSyntheticDefaultImports --skipLibCheck api/index.ts server/index.ts",
    "lint": "eslint .",
    "smoke": "node scripts/smoke.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "latest",
    "@ant-design/plots": "latest",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "latest",
    "antd": "latest",
    "clsx": "^2.1.1",
    "cors": "latest",
    "express": "latest",
    "lucide-react": "^1.23.0",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "latest",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.2",
    "zod": "latest",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "^1.61.0",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "globals": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest"
  }
}
